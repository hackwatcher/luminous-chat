# Ortam Değişkenleri - Örnek Yapılandırma
# Bu dosyayı kopyalayıp ".env" olarak kaydedin ve değerleri doldurun
# .env dosyası asla git'e commit edilmemeli!

# ─── Uygulama ─────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS ─────────────────────────────────────────
# Deploy ettiğiniz domain(ler)i virgülle ayırarak girin
# Örn: https://luminous.onrender.com,https://www.luminous.app
ALLOWED_ORIGINS=https://your-domain.com

# ─── (Opsiyonel) TURN Sunucusu ─────────────────────
# Gerçek kullanıcı ortamında NAT geçişi için TURN sunucusu önerilir.
# Ücretsiz Metered.ca veya kendi COTURN kurulumunuzu kullanabilirsiniz.
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your_username
# TURN_CREDENTIAL=your_credential
